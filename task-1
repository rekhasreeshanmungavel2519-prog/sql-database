-- Students in each course
SELECT c.CourseName, s.Name, e.Grade
FROM Enrollments e
JOIN Students s ON s.StudentID = e.StudentID
JOIN Courses c ON c.CourseID = e.CourseID
ORDER BY c.CourseName;

-- Average marks per course
SELECT c.CourseName, AVG(e.Grade) AS AvgMarks
FROM Enrollments e
JOIN Courses c ON c.CourseID = e.CourseID
GROUP BY c.CourseName;

-- Top 3 students overall
SELECT s.Name, SUM(e.Grade) AS TotalMarks
FROM Enrollments e
JOIN Students s ON s.StudentID = e.StudentID
GROUP BY s.Name
ORDER BY TotalMarks DESC
LIMIT 3;

SELECT c.CourseName, s.Name, e.Grade
FROM Enrollments e
JOIN Students s ON s.StudentID = e.StudentID
JOIN Courses c ON c.CourseID = e.CourseID
ORDER BY c.CourseName, e.Grade DESC;

SELECT c.CourseName,
       COUNT(*) AS TotalStudents,
       SUM(CASE WHEN e.Grade >= 40 THEN 1 ELSE 0 END) AS PassedStudents
FROM Enrollments e
JOIN Courses c ON c.CourseID = e.CourseID
GROUP BY c.CourseName;


SELECT s.Name, SUM(e.Grade) AS TotalMarks
FROM Enrollments e
JOIN Students s ON s.StudentID = e.StudentID
GROUP BY s.Name
ORDER BY TotalMarks DESC
LIMIT 1;

SELECT s.Name, COUNT(e.CourseID) AS CourseCount
FROM Enrollments e
JOIN Students s ON s.StudentID = e.StudentID
GROUP BY s.Name
HAVING COUNT(e.CourseID) > 1;
