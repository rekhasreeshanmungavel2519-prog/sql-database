DROP TABLE IF EXISTS student_details;

CREATE TABLE student_details (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(50),
    gender CHAR(1),
    age INT,
    section CHAR(1),
    mark1 INT,
    mark2 INT,
    mark3 INT
);

