SELECT * FROM student_details;

SELECT name,
       mark1 + mark2 + mark3 AS total_marks
FROM student_details;

SELECT name,
       ROUND((mark1 + mark2 + mark3)/3,2) AS average_marks
FROM student_details;

SELECT name,
       ROUND((mark1 + mark2 + mark3)/3,2) AS average_marks
FROM student_details
ORDER BY average_marks DESC
LIMIT 3;

SELECT section,
       ROUND(AVG((mark1 + mark2 + mark3)/3),2) AS section_average
FROM student_details
GROUP BY section;

SELECT name
FROM student_details
WHERE mark1 < 40
   OR mark2 < 40
   OR mark3 < 40;
